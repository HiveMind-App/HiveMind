{
  "name": "hivemind-cli",
  "version": "0.1.0",
  "description": "HiveMind CLI — Una colmena de IAs, para un equipo de desarrolladores.",
  "type": "module",
  "bin": {
    "hivemind": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "hivemind",
    "gemini",
    "ai",
    "cli",
    "collaboration",
    "mcp"
  ],
  "author": "HiveMind Team",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.103.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "prompts": "^2.4.2",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
