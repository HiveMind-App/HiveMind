# HiveMind CLI — Variables de entorno
# Copia este archivo a .env y rellena los valores de tu instancia HiveMind.
#
# El equipo HiveMind proporciona estos valores al hacer onboarding.
# Si eres maintainer del backend, los encuentras en el panel de Supabase
# (Settings → API).

# URL de tu proyecto Supabase (Settings → API → Project URL)
HIVEMIND_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key pública de Supabase (Settings → API → anon/public)
# Esta clave es segura para distribución en cliente; la seguridad
# la aplican las RLS policies del servidor.
HIVEMIND_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (Opcional) URL del dashboard Watchtower de tu equipo
HIVEMIND_WATCHTOWER_URL=https://hivemind.yourteam.com

# (Opcional) API key de OpenAI para resumir outputs largos
# OPENAI_API_KEY=sk-...

# (Opcional) Binario del CLI de IA a interceptar. Por defecto: gemini
# GEMINI_BIN=gemini

# Nivel de log: silent | info | debug
HIVEMIND_LOG_LEVEL=info
